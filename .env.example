# Copy to .env.local and fill in your values.

# Spotify app credentials from https://developer.spotify.com/dashboard
# The secret must stay server-side — do NOT prefix it with NEXT_PUBLIC_.
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret

# NextAuth
# NEXTAUTH_URL is the site origin (http://localhost:3000 in dev).
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_secret

# Add this Redirect URI in the Spotify dashboard:
#   http://localhost:3000/api/auth/callback/spotify
